---
const currentYear = new Date().getFullYear();
---

<footer class="bg-surface border-t border-white/5 mt-16">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Brand -->
      <div>
        <div class="flex items-center gap-2 mb-4">
          <span class="text-2xl">🌴</span>
          <span class="font-display text-xl font-bold gradient-text">GTA VI Hub</span>
        </div>
        <p class="text-muted text-sm leading-relaxed">
          The ultimate community hub for Grand Theft Auto VI. Built by fans, for fans.
          Tracking news, leaks, trailers, and everything Leonida.
        </p>
        <div class="flex gap-4 mt-4">
          <a href="#" class="text-muted hover:text-neon-pink transition-colors" aria-label="Twitter/X">
            <i class="fa-brands fa-x-twitter text-lg"></i>
          </a>
          <a href="#" class="text-muted hover:text-neon-cyan transition-colors" aria-label="YouTube">
            <i class="fa-brands fa-youtube text-lg"></i>
          </a>
          <a href="#" class="text-muted hover:text-neon-purple transition-colors" aria-label="Discord">
            <i class="fa-brands fa-discord text-lg"></i>
          </a>
          <a href="#" class="text-muted hover:text-neon-gold transition-colors" aria-label="Reddit">
            <i class="fa-brands fa-reddit-alien text-lg"></i>
          </a>
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="font-display font-semibold text-white mb-4">Quick Links</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/news" class="text-muted hover:text-white transition-colors">Latest News</a></li>
          <li><a href="/trailers" class="text-muted hover:text-white transition-colors">Trailers</a></li>
          <li><a href="/map" class="text-muted hover:text-white transition-colors">Interactive Map</a></li>
          <li><a href="/characters" class="text-muted hover:text-white transition-colors">Characters</a></li>
        </ul>
      </div>

      <!-- Stay Updated -->
      <div>
        <h3 class="font-display font-semibold text-white mb-4">Stay Updated</h3>
        <p class="text-muted text-sm mb-3">Get the latest GTA 6 news delivered to your inbox.</p>
        <form class="flex gap-2">
          <input
            type="email"
            placeholder="your@email.com"
            class="flex-1 bg-card border border-white/10 rounded-lg px-3 py-2 text-sm text-white placeholder-muted focus:outline-none focus:border-neon-pink/50 transition-colors"
          />
          <button
            type="submit"
            class="bg-neon-pink text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-neon-pink/80 transition-all glow-pink"
          >
            <i class="fa-solid fa-paper-plane"></i>
          </button>
        </form>
      </div>
    </div>

    <div class="border-t border-white/5 mt-8 pt-8 text-center text-xs text-muted">
      <p>&copy; {currentYear} GTA VI Hub. This is a non-commercial fan project.</p>
      <p class="mt-1">Not affiliated with Rockstar Games or Take-Two Interactive. All assets belong to their respective owners.</p>
    </div>
  </div>
</footer>
