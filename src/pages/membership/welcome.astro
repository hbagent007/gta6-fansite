---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Welcome! 🎉" description="Your hubgta6.com membership is ready">
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pt-16 pb-24">
    
    <!-- Confetti / Hero Area -->
    <div class="relative overflow-hidden rounded-3xl border border-neon-pink/20 bg-gradient-to-br from-neon-pink/5 via-neon-purple/5 to-neon-cyan/5 p-10 md:p-14 mb-10 text-center">
      <!-- Animated glow layers -->
      <div class="absolute -top-24 -right-24 w-72 h-72 bg-neon-cyan rounded-full blur-[120px] opacity-20 animate-pulse-glow"></div>
      <div class="absolute -bottom-24 -left-24 w-72 h-72 bg-neon-pink rounded-full blur-[120px] opacity-20 animate-pulse-glow" style="animation-delay: 1.5s"></div>
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,rgba(180,77,255,0.06),transparent_70%)]"></div>

      <div class="relative z-10">
        <!-- Icon -->
        <div class="w-20 h-20 rounded-full bg-gradient-to-br from-neon-pink via-neon-purple to-neon-cyan flex items-center justify-center mx-auto mb-6 shadow-lg shadow-neon-pink/20">
          <i class="fa-solid fa-check text-3xl text-white"></i>
        </div>

        <h1 class="font-display text-4xl md:text-5xl lg:text-6xl font-black leading-tight mb-3">
          <span class="gradient-text">Welcome Aboard!</span>
        </h1>

        <p class="text-muted text-base md:text-lg max-w-lg mx-auto mb-2">
          Your account is set up and ready to go.
        </p>

        <!-- Membership status badge (filled by JS) -->
        <div id="membership-badge" class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-white/5 border border-white/10 mt-4">
          <i class="fa-solid fa-spinner fa-spin text-neon-cyan"></i>
          <span class="text-sm text-muted">Loading your membership...</span>
        </div>

        <!-- CTA buttons -->
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mt-8">
          <a href="/dashboard" class="inline-flex items-center gap-2 bg-gradient-to-r from-neon-pink to-neon-purple text-white px-8 py-3 rounded-xl font-medium hover:opacity-90 transition-all glow-pink">
            <i class="fa-solid fa-rocket"></i> Go to Dashboard
          </a>
          <a href="/forum" class="inline-flex items-center gap-2 glass text-white px-8 py-3 rounded-xl font-medium hover:bg-white/10 transition-all">
            <i class="fa-solid fa-comments"></i> Explore Forums
          </a>
        </div>
      </div>
    </div>

    <!-- Launch Special Card (shown if premium was claimed) -->
    <div id="premium-card" class="hidden relative overflow-hidden rounded-2xl border border-neon-cyan/30 bg-gradient-to-br from-neon-cyan/5 via-neon-purple/5 to-transparent p-8 mb-8">
      <div class="absolute top-0 right-0 w-40 h-40 bg-neon-cyan rounded-full blur-[80px] opacity-10"></div>
      <div class="relative z-10 flex items-start gap-5">
        <div class="w-14 h-14 rounded-xl bg-gradient-to-br from-neon-cyan to-blue-600 flex items-center justify-center flex-shrink-0">
          <i class="fa-solid fa-crown text-2xl text-white"></i>
        </div>
        <div>
          <h3 class="font-display text-xl font-bold text-neon-cyan mb-1">🎉 You Got Premium — Free!</h3>
          <p class="text-muted text-sm mb-3">
            You were one of the first <strong class="text-white">500 members</strong> to sign up. 
            Your account has been <strong class="text-white">automatically upgraded to Premium</strong> — 
            no payment needed, keep it forever.
          </p>
          <ul class="space-y-1.5 text-sm">
            <li class="flex items-start gap-2 text-muted">
              <i class="fa-solid fa-check text-neon-cyan mt-0.5"></i>
              Full forum posting &amp; replies
            </li>
            <li class="flex items-start gap-2 text-muted">
              <i class="fa-solid fa-check text-neon-cyan mt-0.5"></i>
              Money-making guides &amp; vehicle locations
            </li>
            <li class="flex items-start gap-2 text-muted">
              <i class="fa-solid fa-check text-neon-cyan mt-0.5"></i>
              Secret loot maps &amp; no ads
            </li>
            <li class="flex items-start gap-2 text-muted">
              <i class="fa-solid fa-check text-neon-cyan mt-0.5"></i>
              Premium badge on your profile
            </li>
          </ul>
        </div>
      </div>
    </div>

    <!-- Free Card (shown if regular free member) -->
    <div id="free-card" class="hidden relative overflow-hidden rounded-2xl border border-white/10 bg-card p-8">
      <div class="flex items-start gap-5">
        <div class="w-14 h-14 rounded-xl bg-gradient-to-br from-gray-500 to-gray-600 flex items-center justify-center flex-shrink-0">
          <i class="fa-solid fa-user text-2xl text-white"></i>
        </div>
        <div>
          <h3 class="font-display text-xl font-bold text-white mb-1">Free Member</h3>
          <p class="text-muted text-sm mb-4">
            Your free account is active. You can browse the community, read guides, 
            and check out the interactive map. Upgrade anytime to unlock more features.
          </p>
          <a href="/membership" class="inline-flex items-center gap-2 bg-gradient-to-r from-neon-cyan to-blue-600 text-white px-5 py-2.5 rounded-xl text-sm font-medium hover:opacity-90 transition-all">
            View Upgrade Options <i class="fa-solid fa-arrow-right"></i>
          </a>
        </div>
      </div>
    </div>

    <!-- Next Steps -->
    <div class="mt-10">
      <h2 class="font-display text-2xl font-bold text-center mb-8">
        <span class="gradient-text">What's Next?</span>
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        <a href="/forum" class="bg-card rounded-2xl border border-white/5 p-6 hover:border-neon-cyan/30 transition-all group hover:-translate-y-1 duration-300">
          <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-neon-cyan to-blue-600 flex items-center justify-center mb-4">
            <i class="fa-solid fa-comments text-xl text-white"></i>
          </div>
          <h3 class="font-display font-semibold text-white mb-1 group-hover:text-neon-cyan transition-colors">Join the Discussion</h3>
          <p class="text-xs text-muted">Head to the forums and connect with other GTA VI fans.</p>
        </a>

        <a href="/guides" class="bg-card rounded-2xl border border-white/5 p-6 hover:border-neon-pink/30 transition-all group hover:-translate-y-1 duration-300">
          <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-neon-pink to-neon-purple flex items-center justify-center mb-4">
            <i class="fa-solid fa-book text-xl text-white"></i>
          </div>
          <h3 class="font-display font-semibold text-white mb-1 group-hover:text-neon-pink transition-colors">Read the Guides</h3>
          <p class="text-xs text-muted">Explore money-making strats, vehicle spawns, and secrets.</p>
        </a>

        <a href="/map" class="bg-card rounded-2xl border border-white/5 p-6 hover:border-neon-gold/30 transition-all group hover:-translate-y-1 duration-300">
          <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-neon-gold to-neon-orange flex items-center justify-center mb-4">
            <i class="fa-solid fa-map text-xl text-white"></i>
          </div>
          <h3 class="font-display font-semibold text-white mb-1 group-hover:text-neon-gold transition-colors">Explore the Map</h3>
          <p class="text-xs text-muted">Browse the interactive map of Vice City & Leonida.</p>
        </a>
      </div>
    </div>

  </section>
</BaseLayout>

<script type="module">
  import { loadSupabase } from '../../lib/client.ts';

  const supabase = await loadSupabase();
  const badge = document.getElementById('membership-badge');
  const premiumCard = document.getElementById('premium-card');
  const freeCard = document.getElementById('free-card');

  async function loadMembership() {
    try {
      const { data: { user } } = await supabase.auth.getUser();
      if (!user) {
        badge.innerHTML = '<i class="fa-solid fa-user text-muted"></i><span class="text-sm text-muted">Please log in to see your membership</span>';
        freeCard.classList.remove('hidden');
        return;
      }

      const { data: membership, error } = await supabase
        .from('memberships')
        .select('*')
        .eq('user_id', user.id)
        .single();

      if (error || !membership) {
        // Try fallback API
        const res = await fetch(`/api/membership/status?userId=${user.id}`);
        const data = await res.json();
        if (data.membership) {
          renderBadge(data.membership);
          return;
        }
        badge.innerHTML = '<i class="fa-solid fa-user text-muted"></i><span class="text-sm text-muted">Membership loading...</span>';
        freeCard.classList.remove('hidden');
        return;
      }

      renderBadge(membership);
    } catch (e) {
      console.error('Failed to load membership:', e);
      badge.innerHTML = '<i class="fa-solid fa-user text-muted"></i><span class="text-sm text-muted">Free Member</span>';
      freeCard.classList.remove('hidden');
    }
  }

  function renderBadge(membership) {
    if (membership.tier === 'premium' || membership.tier === 'elite') {
      badge.innerHTML = `
        <i class="fa-solid fa-crown text-neon-cyan"></i>
        <span class="text-sm font-semibold text-neon-cyan">${membership.tier.charAt(0).toUpperCase() + membership.tier.slice(1)} Member</span>
        <span class="text-xs text-muted ml-2 px-2 py-0.5 rounded-full bg-neon-cyan/10 border border-neon-cyan/30">Active</span>
      `;
      premiumCard.classList.remove('hidden');
    } else {
      badge.innerHTML = `
        <i class="fa-solid fa-user text-muted"></i>
        <span class="text-sm text-muted">Free Member</span>
        <span class="text-xs text-green-400 ml-2 px-2 py-0.5 rounded-full bg-green-900/30 border border-green-500/30">Active</span>
      `;
      freeCard.classList.remove('hidden');
    }
  }

  loadMembership();
</script>
