---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { TIERS } from "../../lib/tiers";
---

<BaseLayout title="Membership" description="Join hubgta6.com with free, premium, or elite membership. Get access to exclusive guides, maps, and community features.">
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-8 pb-16">
    <!-- Launch Offer Banner -->
    <div class="text-center mb-8">
      <div class="inline-block bg-gradient-to-r from-neon-pink/20 via-neon-purple/20 to-neon-cyan/20 border border-neon-pink/30 rounded-2xl p-6 md:p-8 max-w-2xl mx-auto relative overflow-hidden">
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_0%,rgba(255,20,147,0.1),transparent)]"></div>
        <div class="relative z-10">
          <span class="inline-block px-4 py-1.5 bg-neon-pink/20 border border-neon-pink/40 rounded-full text-neon-pink text-xs font-bold tracking-wider uppercase mb-3 animate-pulse-glow">
            🚀 LAUNCH SPECIAL
          </span>
          <h2 class="font-display text-3xl md:text-4xl font-bold mb-2">
            First <span class="gradient-text">500</span> Members Go Premium
          </h2>
          <p class="text-muted text-sm md:text-base max-w-lg mx-auto mb-4">
            Simply sign up for a <strong class="text-white">free account</strong> — first 500 people get <strong class="text-white">auto-upgraded to Premium</strong> with no extra cost.
          </p>
          <div class="flex items-center justify-center gap-6 text-sm">
            <div>
              <span class="text-2xl font-bold text-neon-cyan" id="spots-left">500</span>
              <p class="text-xs text-muted">Spots Left</p>
            </div>
            <div class="w-px h-10 bg-white/10"></div>
            <div>
              <span class="text-2xl font-bold text-neon-pink">0</span>
              <p class="text-xs text-muted">Claimed</p>
            </div>
          </div>
          <div class="mt-4 w-full max-w-xs mx-auto bg-deep-bg rounded-full h-2 overflow-hidden border border-white/5">
            <div class="h-full w-0 bg-gradient-to-r from-neon-pink to-neon-cyan rounded-full transition-all duration-500" id="progress-bar"></div>
          </div>
        </div>
      </div>
    </div>

    <!-- Header -->
    <div class="text-center mb-12">
      <h1 class="font-display text-4xl md:text-5xl font-bold mb-4">
        <span class="gradient-text">Choose Your Tier</span>
      </h1>
      <p class="text-muted max-w-2xl mx-auto">
        Unlock exclusive GTA VI content, guides, and community features. Upgrade anytime to access more.
      </p>
    </div>

    <!-- Pricing Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-5xl mx-auto" id="pricing-cards">
      {Object.values(TIERS).map((tier) => (
        <div class={`bg-card rounded-2xl border border-white/5 p-6 md:p-8 relative transition-all hover:-translate-y-1 duration-300 ${
          tier.id === 'elite' ? 'ring-2 ring-neon-pink/40 shadow-lg shadow-neon-pink/10' : ''
        }`}>
          {tier.id === 'elite' && (
            <div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-gradient-to-r from-neon-pink to-neon-purple text-white text-xs font-semibold px-4 py-1 rounded-full">
              Most Popular
            </div>
          )}

          <div class="text-center mb-6">
            <div class={`w-16 h-16 rounded-2xl bg-gradient-to-br ${tier.color} flex items-center justify-center mx-auto mb-4`}>
              {tier.id === 'free' && <i class="fa-solid fa-user text-2xl text-white"></i>}
              {tier.id === 'premium' && <i class="fa-solid fa-star text-2xl text-white"></i>}
              {tier.id === 'elite' && <i class="fa-solid fa-crown text-2xl text-white"></i>}
            </div>
            <h3 class="font-display text-xl font-bold">{tier.name}</h3>
            {tier.price > 0 ? (
              <div class="mt-2">
                <span class="text-3xl font-bold">${tier.price}</span>
                <span class="text-muted text-sm">/month</span>
              </div>
            ) : (
              <p class="text-muted text-sm mt-2">Free forever</p>
            )}
          </div>

          <ul class="space-y-3 mb-8">
            {tier.features.map((feature) => (
              <li class="flex items-start gap-3 text-sm">
                <i class={`fa-solid fa-check mt-0.5 ${
                  tier.id === 'free' ? 'text-muted' : tier.id === 'premium' ? 'text-neon-cyan' : 'text-neon-pink'
                }`}></i>
                <span class="text-muted">{feature}</span>
              </li>
            ))}
          </ul>

          {tier.id === 'free' ? (
            <button class="w-full glass text-white py-3 rounded-xl text-sm font-medium cursor-pointer hover:bg-white/10 transition-all" onclick="document.getElementById('auth-modal').classList.remove('hidden')">
              Get Started Free
            </button>
          ) : (
            <button
              class="checkout-btn w-full bg-gradient-to-r from-neon-pink to-neon-purple text-white py-3 rounded-xl text-sm font-medium hover:opacity-90 transition-all glow-pink cursor-pointer"
              data-tier={tier.id}
              data-price={tier.price}
            >
              Subscribe — ${tier.priceLabel}
            </button>
          )}
        </div>
      ))}
    </div>

    <!-- FAQ -->
    <div class="mt-16 max-w-3xl mx-auto">
      <h2 class="font-display text-2xl font-bold text-center mb-8">Frequently Asked Questions</h2>
      <div class="space-y-4">
        <details class="bg-card rounded-xl border border-white/5 p-4 open:border-neon-cyan/30 transition-all">
          <summary class="font-medium text-white cursor-pointer">Can I cancel anytime?</summary>
          <p class="text-sm text-muted mt-3">Yes! You can cancel your subscription at any time. Your access continues until the end of your billing period.</p>
        </details>
        <details class="bg-card rounded-xl border border-white/5 p-4 open:border-neon-cyan/30 transition-all">
          <summary class="font-medium text-white cursor-pointer">What payment methods do you accept?</summary>
          <p class="text-sm text-muted mt-3">All major credit and debit cards via Stripe. Apple Pay and Google Pay also supported.</p>
        </details>
        <details class="bg-card rounded-xl border border-white/5 p-4 open:border-neon-cyan/30 transition-all">
          <summary class="font-medium text-white cursor-pointer">Can I upgrade or downgrade?</summary>
          <p class="text-sm text-muted mt-3">Absolutely. You can change your plan at any time. Upgrades take effect immediately, downgrades at the end of your billing period.</p>
        </details>
        <details class="bg-card rounded-xl border border-white/5 p-4 open:border-neon-cyan/30 transition-all">
          <summary class="font-medium text-white cursor-pointer">Is this site official?</summary>
          <p class="text-sm text-muted mt-3">No. hubgta6.com is a non-commercial fan project. We are not affiliated with Rockstar Games or Take-Two Interactive.</p>
        </details>
      </div>
    </div>
  </section>

  <!-- Auth Modal (hidden by default) -->
  <div id="auth-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/70 backdrop-blur-sm">
    <div class="bg-card rounded-2xl border border-white/10 p-8 w-full max-w-md mx-4 relative">
      <button id="close-auth" class="absolute top-4 right-4 text-muted hover:text-white cursor-pointer" onclick="document.getElementById('auth-modal').classList.add('hidden')">
        <i class="fa-solid fa-xmark text-xl"></i>
      </button>
      <div class="text-center mb-6">
        <div class="w-14 h-14 rounded-xl bg-gradient-to-br from-neon-pink to-neon-purple flex items-center justify-center mx-auto mb-3">
          <i class="fa-solid fa-user-astronaut text-2xl text-white"></i>
        </div>
        <h2 class="font-display text-2xl font-bold">Join hubgta6.com</h2>
        <p class="text-muted text-sm mt-1">Sign up or log in to access all features</p>
      </div>

      <form id="auth-form" class="space-y-4">
        <div id="auth-error" class="hidden bg-red-900/30 border border-red-500/30 text-red-400 text-sm rounded-xl p-3"></div>
        <div id="email-field">
          <label class="block text-sm text-muted mb-1">Email</label>
          <input type="email" id="auth-email" required placeholder="your@email.com" class="w-full bg-deep-bg border border-white/10 rounded-xl px-4 py-3 text-sm text-white placeholder-muted focus:outline-none focus:border-neon-pink/50" />
        </div>
        <div id="password-field">
          <label class="block text-sm text-muted mb-1">Password</label>
          <input type="password" id="auth-password" required placeholder="At least 6 characters" minlength="6" class="w-full bg-deep-bg border border-white/10 rounded-xl px-4 py-3 text-sm text-white placeholder-muted focus:outline-none focus:border-neon-pink/50" />
        </div>
        <button type="submit" id="auth-submit" class="w-full bg-gradient-to-r from-neon-pink to-neon-purple text-white py-3 rounded-xl font-medium hover:opacity-90 transition-all">
          Sign Up
        </button>
      </form>

      <div class="mt-4 text-center">
        <button id="auth-toggle" class="text-sm text-neon-cyan hover:text-neon-cyan/80 transition-colors cursor-pointer">
          Already have an account? Log in
        </button>
      </div>
    </div>
  </div>
</BaseLayout>

<script type="module">
  import { loadSupabase, loadStripeClient } from '../../lib/client.ts';

  const supabase = await loadSupabase();
  let isLogin = false;
  const form = document.getElementById('auth-form');
  const toggle = document.getElementById('auth-toggle');
  const errorEl = document.getElementById('auth-error');
  const submitBtn = document.getElementById('auth-submit');
  const emailField = document.getElementById('auth-email');
  const passwordField = document.getElementById('auth-password');

  // Toggle login/signup
  toggle?.addEventListener('click', () => {
    isLogin = !isLogin;
    submitBtn.textContent = isLogin ? 'Log In' : 'Sign Up';
    toggle.textContent = isLogin ? "Don't have an account? Sign up" : 'Already have an account? Log in';
  });

  // Load launch counter
  async function loadLaunchCounter() {
    if (!supabase) return;
    try {
      const { count, error } = await supabase
        .from('launch_registrations')
        .select('*', { count: 'exact', head: true });
      if (!error && count !== null) {
        const left = Math.max(0, 500 - count);
        const el = document.getElementById('spots-left');
        const bar = document.getElementById('progress-bar');
        if (el) el.textContent = left;
        if (bar) bar.style.width = `${(count / 500) * 100}%`;
      }
    } catch (e) {
      console.log('Launch counter unavailable (set up Supabase to enable)');
    }
  }
  loadLaunchCounter();

  // Handle auth
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorEl.classList.add('hidden');
    submitBtn.disabled = true;
    submitBtn.textContent = 'Loading...';

    const email = emailField.value;
    const password = passwordField.value;

    try {
      if (isLogin) {
        const { error } = await supabase.auth.signInWithPassword({ email, password });
        if (error) throw error;
        location.reload();
      } else {
        const signupResult = await supabase.auth.signUp({
          email,
          password,
          options: { data: { username: email.split('@')[0] } }
        });
        if (signupResult.error) throw signupResult.error;

        // Track launch registration if spots are available
        if (signupResult.data?.user) {
          // Check remaining spots
          const { count } = await supabase
            .from('launch_registrations')
            .select('*', { count: 'exact', head: true });
          
          if (!count || count < 500) {
            await supabase.from('launch_registrations').insert({
              user_id: signupResult.data.user.id,
              email: email,
              claimed_premium: true,
            });
            // Update their membership to premium
            await supabase.from('memberships').upsert({
              user_id: signupResult.data.user.id,
              tier: 'premium',
            });
            errorEl.classList.remove('hidden');
            errorEl.innerHTML = '<i class="fa-solid fa-crown mr-2"></i>Welcome! You\'re one of the first 500 — <strong>Premium activated FREE!</strong>';
            errorEl.style.cssText = 'background: rgba(0,240,255,0.1); border-color: rgba(0,240,255,0.3); color: #00f0ff;';
          } else {
            errorEl.classList.remove('hidden');
            errorEl.textContent = 'Sign up complete! Check your email for confirmation.';
            errorEl.classList.remove('bg-red-900/30', 'border-red-500/30', 'text-red-400');
            errorEl.classList.add('bg-green-900/30', 'border-green-500/30', 'text-green-400');
          }
          
          // Refresh counter
          loadLaunchCounter();
        }
      }
    } catch (err) {
      errorEl.classList.remove('hidden');
      errorEl.textContent = err.message;
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = isLogin ? 'Log In' : 'Sign Up';
    }
  });

  // Checkout buttons
  document.querySelectorAll('.checkout-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const tier = btn.dataset.tier;
      const { data: { user } } = await supabase.auth.getUser();
      if (!user) {
        document.getElementById('auth-modal').classList.remove('hidden');
        return;
      }

      btn.disabled = true;
      btn.textContent = 'Redirecting...';

      try {
        // Call our API to create a Stripe checkout session
        const res = await fetch('/api/create-checkout', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ tier, userId: user.id, email: user.email }),
        });
        const { url, error } = await res.json();
        if (error) throw new Error(error);
        window.location.href = url;
      } catch (err) {
        errorEl.classList.remove('hidden');
        errorEl.textContent = err.message;
        btn.disabled = false;
        btn.textContent = `Subscribe — \$${btn.dataset.price}/month`;
      }
    });
  });
</script>
