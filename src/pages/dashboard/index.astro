---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="My Dashboard" description="Your GTA VI Hub member dashboard">
  <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 pt-8 pb-16">
    <!-- Greeting -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-10">
      <div>
        <h1 class="font-display text-3xl font-bold">
          Welcome back<span id="user-display" class="gradient-text">, Member</span>
        </h1>
        <p class="text-muted text-sm mt-1" id="user-tier">Free Member</p>
      </div>
      <button id="logout-btn" class="glass text-muted hover:text-white px-4 py-2 rounded-xl text-sm transition-colors cursor-pointer">
        <i class="fa-solid fa-right-from-bracket mr-2"></i>Sign Out
      </button>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      <!-- Left: Profile -->
      <div class="lg:col-span-2 space-y-6">
        <!-- Membership Card -->
        <div id="membership-card" class="bg-card rounded-2xl border border-white/5 p-6">
          <div class="flex items-center justify-between mb-4">
            <h2 class="font-display font-semibold text-lg">Your Membership</h2>
            <span id="current-tier-badge" class="text-xs font-medium px-3 py-1 rounded-full bg-green-900/30 text-green-400 border border-green-500/30">Free</span>
          </div>
          <div id="free-actions">
            <p class="text-muted text-sm mb-4">You're currently on the Free plan. Upgrade to unlock exclusive content.</p>
            <a href="/membership" class="inline-flex items-center gap-2 bg-gradient-to-r from-neon-cyan to-blue-600 text-white px-5 py-2.5 rounded-xl text-sm font-medium hover:opacity-90 transition-all">
              View Plans <i class="fa-solid fa-arrow-right"></i>
            </a>
          </div>
          <div id="paid-actions" class="hidden">
            <p class="text-muted text-sm mb-2">
              <i class="fa-regular fa-circle-check text-neon-cyan mr-1"></i>
              Your subscription is <strong class="text-white">active</strong>
            </p>
            <p class="text-xs text-muted mb-4">
              Next billing date: <span id="next-billing">--</span>
            </p>
            <button class="glass text-muted hover:text-white px-4 py-2 rounded-xl text-xs transition-colors cursor-pointer">
              Manage Billing <i class="fa-solid fa-arrow-up-right-from-square ml-1"></i>
            </button>
          </div>
        </div>

        <!-- Recent Activity -->
        <div class="bg-card rounded-2xl border border-white/5 p-6">
          <h2 class="font-display font-semibold text-lg mb-4">Recent Activity</h2>
          <div class="space-y-4 text-sm">
            <div class="flex items-start gap-3 pb-3 border-b border-white/5">
              <i class="fa-solid fa-message text-neon-cyan mt-1"></i>
              <div>
                <p class="text-white">Replied to <a href="#" class="text-neon-cyan hover:underline">"Best money method?"</a></p>
                <p class="text-xs text-muted mt-0.5">2 hours ago</p>
              </div>
            </div>
            <div class="flex items-start gap-3 pb-3 border-b border-white/5">
              <i class="fa-solid fa-thumbs-up text-neon-pink mt-1"></i>
              <div>
                <p class="text-white">Liked a guide: <a href="#" class="text-neon-pink hover:underline">"Rare Car Spawns"</a></p>
                <p class="text-xs text-muted mt-0.5">Yesterday</p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <i class="fa-solid fa-user-plus text-neon-gold mt-1"></i>
              <div>
                <p class="text-white">Joined GTA VI Hub</p>
                <p class="text-xs text-muted mt-0.5">3 days ago</p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Right: Stats -->
      <div class="space-y-6">
        <div class="bg-card rounded-2xl border border-white/5 p-6 text-center">
          <div class="w-16 h-16 rounded-full bg-gradient-to-br from-neon-pink to-neon-purple flex items-center justify-center mx-auto mb-3">
            <i class="fa-solid fa-user text-2xl text-white"></i>
          </div>
          <p id="user-name" class="font-display font-semibold">Loading...</p>
          <p id="user-email" class="text-xs text-muted mt-1">Loading...</p>
          <hr class="border-white/5 my-4" />
          <div class="grid grid-cols-3 gap-4 text-sm">
            <div>
              <p class="font-semibold text-white" id="stat-threads">0</p>
              <p class="text-xs text-muted">Threads</p>
            </div>
            <div>
              <p class="font-semibold text-white" id="stat-posts">0</p>
              <p class="text-xs text-muted">Posts</p>
            </div>
            <div>
              <p class="font-semibold text-white" id="stat-likes">0</p>
              <p class="text-xs text-muted">Likes</p>
            </div>
          </div>
        </div>

        <!-- Quick Links -->
        <div class="bg-card rounded-2xl border border-white/5 p-6">
          <h3 class="font-display font-semibold text-sm mb-4">Quick Access</h3>
          <div class="space-y-2">
            <a href="/forum" class="flex items-center gap-3 text-sm text-muted hover:text-white transition-colors p-2 rounded-lg hover:bg-white/5">
              <i class="fa-solid fa-comments w-5 text-neon-cyan"></i> Forums
            </a>
            <a href="/guides" class="flex items-center gap-3 text-sm text-muted hover:text-white transition-colors p-2 rounded-lg hover:bg-white/5">
              <i class="fa-solid fa-book w-5 text-neon-pink"></i> Guides
            </a>
            <a href="/map" class="flex items-center gap-3 text-sm text-muted hover:text-white transition-colors p-2 rounded-lg hover:bg-white/5">
              <i class="fa-solid fa-map w-5 text-neon-gold"></i> Interactive Map
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script type="module">
  import { loadSupabase } from '../../lib/client.ts';
  const supabase = await loadSupabase();

  async function loadDashboard() {
    const { data: { user }, error } = await supabase.auth.getUser();
    if (error || !user) {
      window.location.href = '/membership';
      return;
    }

    document.getElementById('user-name').textContent = user.email?.split('@')[0] || 'User';
    document.getElementById('user-email').textContent = user.email;

    // Load membership status
    const { data: membership } = await supabase
      .from('memberships')
      .select('*')
      .eq('user_id', user.id)
      .single();

    if (membership) {
      const tier = membership.tier;
      document.getElementById('user-tier').textContent =
        tier === 'free' ? 'Free Member' :
        tier === 'premium' ? 'Premium Member' :
        'Elite Member';

      const badge = document.getElementById('current-tier-badge');
      badge.textContent = tier.charAt(0).toUpperCase() + tier.slice(1);
      badge.className = `text-xs font-medium px-3 py-1 rounded-full border ${
        tier === 'free'
          ? 'bg-green-900/30 text-green-400 border-green-500/30'
          : tier === 'premium'
          ? 'bg-neon-cyan/10 text-neon-cyan border-neon-cyan/30'
          : 'bg-neon-pink/10 text-neon-pink border-neon-pink/30'
      }`;

      document.getElementById('user-display').textContent = `, ${tier.charAt(0).toUpperCase() + tier.slice(1)} Member`;

      if (tier !== 'free') {
        document.getElementById('free-actions').classList.add('hidden');
        document.getElementById('paid-actions').classList.remove('hidden');
        if (membership.current_period_end) {
          document.getElementById('next-billing').textContent =
            new Date(membership.current_period_end).toLocaleDateString();
        }
      }
    }
  }

  loadDashboard();

  document.getElementById('logout-btn')?.addEventListener('click', async () => {
    await supabase.auth.signOut();
    window.location.href = '/';
  });
</script>
