---
import BaseLayout from "../../layouts/BaseLayout.astro";

const categories = [
  { name: "General Discussion", slug: "general", desc: "Chat about GTA VI, gaming, and anything else", threads: 142, posts: 2_847, minTier: "free" },
  { name: "News & Rumors", slug: "news-rumors", desc: "Discuss the latest GTA VI news, leaks, and rumors", threads: 89, posts: 1_563, minTier: "free" },
  { name: "Maps & Locations", slug: "maps-locations", desc: "Share and find locations, Easter eggs, and secrets", threads: 67, posts: 892, minTier: "free" },
  { name: "Money Making Guides", slug: "money-guides", desc: "Best methods to make money in GTA VI", threads: 34, posts: 521, minTier: "premium" },
  { name: "Car & Vehicle Hub", slug: "cars-vehicles", desc: "Vehicle locations, stats, and customization", threads: 41, posts: 678, minTier: "premium" },
  { name: "Elite Lounge", slug: "elite-lounge", desc: "Exclusive early access content and elite discussion", threads: 12, posts: 203, minTier: "elite" },
  { name: "Showcase & Creations", slug: "showcase", desc: "Share your screenshots, clips, and fan creations", threads: 55, posts: 934, minTier: "free" },
];
---

<BaseLayout title="Forums" description="Join the GTA VI community forums. Discuss news, share maps, and connect with other players.">
  <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 pt-8 pb-16">
    <!-- Header -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-8">
      <div>
        <h1 class="font-display text-3xl md:text-4xl font-bold">
          <span class="gradient-text">Community Forums</span>
        </h1>
        <p class="text-muted text-sm mt-1">
          <i class="fa-regular fa-message mr-1"></i> 440 threads · 7,638 posts · <span class="text-neon-green">48 online</span>
        </p>
      </div>
      <a href="/forum/new" class="inline-flex items-center gap-2 bg-neon-pink text-white px-5 py-2.5 rounded-xl text-sm font-medium hover:bg-neon-pink/80 transition-all glow-pink shrink-0">
        <i class="fa-solid fa-plus"></i> New Thread
      </a>
    </div>

    <!-- Category List -->
    <div class="space-y-3">
      {categories.map((cat, idx) => {
        const isLocked = cat.minTier !== 'free';
        return (
          <a
            href={isLocked ? '/membership' : `/forum/${cat.slug}`}
            class={`block bg-card rounded-2xl border border-white/5 p-5 hover:border-white/10 transition-all group relative ${
              isLocked ? 'opacity-70' : ''
            }`}
            style={`animation: fade-in 0.3s ease-out forwards; animation-delay: ${idx * 0.05}s`}
          >
            <div class="flex items-start justify-between gap-4">
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-3 mb-1">
                  <h2 class="font-display font-semibold text-lg group-hover:text-neon-cyan transition-colors">
                    {cat.name}
                  </h2>
                  {cat.minTier !== 'free' && (
                    <span class={`text-xs font-medium px-2 py-0.5 rounded-full border ${
                      cat.minTier === 'premium'
                        ? 'bg-neon-cyan/10 text-neon-cyan border-neon-cyan/30'
                        : 'bg-neon-pink/10 text-neon-pink border-neon-pink/30'
                    }`}>
                      <i class="fa-solid fa-lock mr-1"></i>{cat.minTier}
                    </span>
                  )}
                </div>
                <p class="text-sm text-muted">{cat.desc}</p>
              </div>
              <div class="hidden sm:flex items-center gap-6 text-xs text-muted shrink-0">
                <div class="text-center">
                  <p class="font-semibold text-white">{cat.threads.toLocaleString()}</p>
                  <p>threads</p>
                </div>
                <div class="text-center">
                  <p class="font-semibold text-white">{cat.posts.toLocaleString()}</p>
                  <p>posts</p>
                </div>
              </div>
              <i class="fa-solid fa-chevron-right text-muted group-hover:text-white transition-colors self-center"></i>
            </div>
          </a>
        );
      })}
    </div>

    <!-- Locked Category Notice -->
    <div class="mt-8 bg-card rounded-2xl border border-white/5 p-6 text-center">
      <i class="fa-solid fa-lock-open text-2xl text-muted mb-3"></i>
      <h3 class="font-display font-semibold text-lg mb-2">Some forums are locked</h3>
      <p class="text-muted text-sm max-w-lg mx-auto mb-4">
        Premium and Elite categories are hidden behind membership tiers. Upgrade to access money guides, vehicle hubs, and the elite lounge.
      </p>
      <a href="/membership" class="bg-gradient-to-r from-neon-pink to-neon-purple text-white px-6 py-2.5 rounded-xl text-sm font-medium inline-block hover:opacity-90 transition-all">
        View Membership Tiers <i class="fa-solid fa-arrow-right ml-2"></i>
      </a>
    </div>
  </section>
</BaseLayout>
