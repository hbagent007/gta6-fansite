---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="General Discussion" description="GTA VI General Discussion forum">
  <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 pt-8 pb-16">
    <!-- Breadcrumb -->
    <div class="text-sm text-muted mb-6">
      <a href="/forum" class="hover:text-white transition-colors">Forums</a>
      <span class="mx-2">/</span>
      <span class="text-white">General Discussion</span>
    </div>

    <!-- Header -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-8">
      <div>
        <h1 class="font-display text-3xl font-bold">General Discussion</h1>
        <p class="text-muted text-sm mt-1">Chat about GTA VI, gaming, and anything else</p>
      </div>
      <a href="/forum/new" class="inline-flex items-center gap-2 bg-neon-pink text-white px-5 py-2.5 rounded-xl text-sm font-medium hover:bg-neon-pink/80 transition-all glow-pink shrink-0">
        <i class="fa-solid fa-plus"></i> New Thread
      </a>
    </div>

    <!-- Pinned Thread -->
    <div class="bg-card rounded-2xl border border-neon-cyan/20 p-4 mb-4">
      <div class="flex items-start gap-3">
        <i class="fa-solid fa-thumbtack text-neon-cyan mt-1"></i>
        <div class="flex-1 min-w-0">
          <a href="/forum/thread/welcome" class="font-medium text-white hover:text-neon-cyan transition-colors">Welcome to GTA VI Hub Forums — Read This First!</a>
          <p class="text-xs text-muted mt-1">Pinned by admin · 1.2k views</p>
        </div>
        <span class="text-xs text-muted shrink-0">2d ago</span>
      </div>
    </div>

    <!-- Thread List -->
    <div class="space-y-2">
      {[1,2,3,4,5,6,7,8].map((i) => (
        <a href="/forum/thread/sample" class="block bg-card rounded-xl border border-white/5 p-4 hover:border-white/10 transition-all group">
          <div class="flex items-start gap-3">
            <div class="w-9 h-9 rounded-full bg-gradient-to-br from-neon-pink/50 to-neon-purple/50 flex items-center justify-center text-xs font-bold shrink-0">
              U{i}
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-sm font-medium group-hover:text-neon-cyan transition-colors line-clamp-1">
                Sample thread title about GTA VI #{i}
              </h3>
              <div class="flex items-center gap-3 text-xs text-muted mt-1">
                <span>User{i}</span>
                <span>·</span>
                <span>{i*3} replies</span>
                <span>·</span>
                <span>{i*42} views</span>
              </div>
            </div>
            <span class="text-xs text-muted shrink-0">{i}h ago</span>
          </div>
        </a>
      ))}
    </div>

    <!-- Pagination -->
    <div class="flex justify-center gap-2 mt-8">
      <button class="px-4 py-2 bg-card border border-white/10 rounded-xl text-sm text-muted hover:text-white transition-colors cursor-pointer">Prev</button>
      <button class="px-4 py-2 bg-neon-pink text-white rounded-xl text-sm font-medium">1</button>
      <button class="px-4 py-2 bg-card border border-white/10 rounded-xl text-sm text-muted hover:text-white transition-colors cursor-pointer">2</button>
      <button class="px-4 py-2 bg-card border border-white/10 rounded-xl text-sm text-muted hover:text-white transition-colors cursor-pointer">3</button>
      <span class="px-2 self-center text-muted text-sm">...</span>
      <button class="px-4 py-2 bg-card border border-white/10 rounded-xl text-sm text-muted hover:text-white transition-colors cursor-pointer">12</button>
      <button class="px-4 py-2 bg-card border border-white/10 rounded-xl text-sm text-muted hover:text-white transition-colors cursor-pointer">Next</button>
    </div>
  </section>
</BaseLayout>
