---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Interactive Map" description="Explore the Leonida interactive map with pinned locations, screenshots, and community notes.">
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-8 pb-16">
    <div class="text-center mb-10">
      <h1 class="font-display text-4xl md:text-5xl font-bold mb-4">
        <span class="gradient-text">Leonida Interactive Map</span>
      </h1>
      <p class="text-muted max-w-2xl mx-auto">
        Explore the sprawling state of Leonida. Click pins for screenshots, descriptions, and community notes.
        <span class="block text-xs mt-2 text-muted/60">Powered by OpenStreetMap &amp; Leaflet.js</span>
      </p>
    </div>

    <!-- Map Container -->
    <div class="bg-card rounded-2xl border border-white/5 overflow-hidden">
      <div id="map" class="w-full h-[70vh] min-h-[500px] z-0"></div>
    </div>

    <!-- Legend -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mt-6">
      <div class="flex items-center gap-3 bg-card rounded-xl p-3 border border-white/5">
        <div class="w-4 h-4 rounded-full bg-neon-pink"></div>
        <span class="text-xs text-muted">Landmark</span>
      </div>
      <div class="flex items-center gap-3 bg-card rounded-xl p-3 border border-white/5">
        <div class="w-4 h-4 rounded-full bg-neon-cyan"></div>
        <span class="text-xs text-muted">Mission Location</span>
      </div>
      <div class="flex items-center gap-3 bg-card rounded-xl p-3 border border-white/5">
        <div class="w-4 h-4 rounded-full bg-neon-gold"></div>
        <span class="text-xs text-muted">Collectible</span>
      </div>
      <div class="flex items-center gap-3 bg-card rounded-xl p-3 border border-white/5">
        <div class="w-4 h-4 rounded-full bg-neon-purple"></div>
        <span class="text-xs text-muted">Community Pin</span>
      </div>
    </div>

    <!-- Community Pin Notice -->
    <div class="mt-8 bg-card rounded-2xl border border-white/5 p-6 text-center">
      <i class="fa-solid fa-location-dot text-2xl text-neon-cyan mb-3"></i>
      <h3 class="font-display font-semibold text-lg mb-2">Want to Contribute?</h3>
      <p class="text-muted text-sm max-w-lg mx-auto mb-4">
        Found a location we missed? Submit a community pin with screenshots and descriptions. All submissions are moderated.
      </p>
      <button class="glass text-white px-6 py-2.5 rounded-xl text-sm font-medium hover:bg-white/10 transition-all cursor-pointer">
        <i class="fa-solid fa-plus mr-2"></i>Submit a Pin
      </button>
    </div>
  </section>
</BaseLayout>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const mapEl = document.getElementById('map');
    if (!mapEl || typeof L === 'undefined') return;

    // Initialize map centered on a mock Leonida / Vice City area
    const map = L.map('map', {
      center: [25.7617, -80.1918], // Miami coordinates as stand-in
      zoom: 11,
      zoomControl: true,
      attributionControl: true,
    });

    // OpenStreetMap tiles
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors',
      maxZoom: 18,
    }).addTo(map);

    // Sample POIs
    const pois = [
      { lat: 25.7741, lng: -80.1939, name: 'Vice Beach', desc: 'Iconic beachfront district with boardwalk and nightclubs.', type: 'landmark' },
      { lat: 25.7617, lng: -80.1918, name: 'Downtown Vice', desc: 'City center with skyscrapers, neon lights, and bustling streets.', type: 'landmark' },
      { lat: 25.8500, lng: -80.1950, name: 'Leonida Wetlands', desc: 'Swampy outskirts with wildlife — alligators spotted here.', type: 'mission' },
      { lat: 25.7300, lng: -80.2300, name: 'Port of Vice', desc: 'Industrial shipping port and rumored smuggling hub.', type: 'mission' },
      { lat: 25.7900, lng: -80.1500, name: 'Starfish Island', desc: 'Luxury residential island — home to the city\'s elite.', type: 'landmark' },
      { lat: 25.8200, lng: -80.1700, name: 'Hidden Package #1', desc: 'Hidden collectible in an abandoned warehouse.', type: 'collectible' },
    ];

    const iconColors = {
      landmark: 'var(--color-neon-pink, #ff1493)',
      mission: 'var(--color-neon-cyan, #00f0ff)',
      collectible: 'var(--color-neon-gold, #ffd700)',
    };

    pois.forEach((poi) => {
      const color = iconColors[poi.type] || '#888';

      const markerIcon = L.divIcon({
        className: 'custom-marker',
        html: `<div style="width:20px;height:20px;background:${color};border:2px solid white;border-radius:50%;box-shadow:0 0 12px ${color}80;"></div>`,
        iconSize: [20, 20],
        iconAnchor: [10, 10],
      });

      const marker = L.marker([poi.lat, poi.lng], { icon: markerIcon }).addTo(map);

      marker.bindPopup(`
        <div style="font-family:system-ui,sans-serif;max-width:250px;">
          <h3 style="font-weight:600;margin:0 0 4px;">${poi.name}</h3>
          <p style="margin:0;font-size:13px;color:#666;">${poi.desc}</p>
          <p style="margin:8px 0 0;font-size:11px;color:#999;">
            <span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:${color};margin-right:4px;"></span>
            ${poi.type.charAt(0).toUpperCase() + poi.type.slice(1)}
          </p>
        </div>
      `);
    });
  });
</script>

<style is:global>
  .custom-marker { background: none; border: none; }
  .leaflet-popup-content-wrapper { border-radius: 12px !important; }
  .leaflet-popup-tip { display: none; }
</style>
